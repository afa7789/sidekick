# ==========================================
# Sidekick Central Configuration
# ==========================================

# TIP: Run `npx llmfit` in your terminal to discover
# which is the best model (7B, 14B, etc.) supported by your machine!

# Hugging Face Repository and GGUF file
# LFM2-24B: Liquid AI's 24B MoE model — fast, strong at instruction following and writing
MODEL_REPO="liquid-tech/LFM2-24B-GGUF"
MODEL_FILE="LFM2-24B-A2B.Q8_0.gguf"

# Directory where models are stored.
# Supports absolute paths and paths relative to this project's root.
#
# Standalone (sidekick is its own project):
#   MODELS_DIR="./models"
#
# Inside local-code (sidekick lives at local-code/sidekick/):
#   MODELS_DIR="../models"
#
# Pointing to local-code from anywhere:
#   MODELS_DIR="/absolute/path/to/models"
MODELS_DIR="./models"

# Port where llama.cpp API will run locally
LLAMA_PORT=8080

# ==========================================
# llama.cpp Performance and Memory Tuning
# ==========================================
# Why this matters:
# - On macOS (Metal), aggressive values can crash with:
#   "Insufficient Memory (kIOGPUCommandBufferCallbackErrorOutOfMemory)"
# - Context size and GPU layers are the main memory drivers.
#
# Recommended conservative profile (for stability / fewer OOMs):
# - LLAMA_NGL=20
# - LLAMA_CTX=2048
# - LLAMA_BATCH=64
# - LLAMA_UBATCH=64
#
# "Balanced" profile (if you have more headroom):
# - LLAMA_NGL=40
# - LLAMA_CTX=8192
# - LLAMA_BATCH=512
# - LLAMA_UBATCH=512
#
# WARNING:
# - Avoid LLAMA_CTX=16384 unless you are sure your machine supports it.
# - If you see Metal OOM errors, reduce LLAMA_CTX first, then LLAMA_NGL.

# Number of layers offloaded to GPU. Higher may be faster, but uses more VRAM.
LLAMA_NGL=20

# Context window (tokens). Main memory pressure knob.
LLAMA_CTX=2048

# Batch size for prompt processing.
LLAMA_BATCH=64

# Micro-batch size to reduce memory spikes.
LLAMA_UBATCH=64

# CPU threads for llama.cpp.
LLAMA_THREADS=8

# Flash Attention reduces attention memory traffic and can improve speed.
# - on/true: force it on (usually faster)
# - off/false: disable it (use this if you see instability)
# - auto: let llama.cpp decide
# Accepted: true/false, on/off, or auto
LLAMA_FA=off

# Port where Silverbullet (notes UI) will run locally
NOTES_PORT=3000

# Directory where your markdown notes are stored
NOTES_DIR="./notes"

# OpenRouter API key (get one at https://openrouter.ai)
OPENROUTER_API_KEY="your-openrouter-api-key"
